{
  "name": "internal_gains",
  "strict": true,
  "schema": {
	"type": "object",
	"properties": {
	  "people": {
        "type": "object",
        "properties": {
          "people_density": {
            "type": "object",
            "properties": {
				"calculation_method": {
					"type": "string",
					"enum": ["People", "People/Area", "Area/Person"]
				},
				"value": {
					"type": "number",
					"description": "The amount of people according to the calculation_method"
				}
			}	
          },
          "activity_level_W": {
            "type": "number",
            "description": "Metabolic rate per person in Watts (seated=120, office=140, standing=160, light work=200)"
          },
          "occupancy_start": {
            "type": "string",
            "description": "HH:MM 24-h start time (e.g. 08:00)"
          },
          "occupancy_end": {
            "type": "string",
            "description": "HH:MM 24-h end time (e.g. 18:00)"
          },
		  "occupied_days": {
			  "type": "array",
			  "items": {
				  "type": "string",
				  "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
			  }
		  }
        },
        "required": ["people_density", "activity_level_W", "occupancy_start", "occupancy_end", "occupied_days"]
      },
	  "lights": {
            "type": "object",
            "properties": {
                "lights_density": {
					"type": "object",
					"properties": {
						"calculation_method": {
							"type": "string",
							"enum": ["LightingLevel", "Watts/Area", "Watts/Person"]
						},
						"value": {
							"type": "number",
							"description": "The amount of lights according to the calculation_method"
						}
					}
				},
				"after_hours_fraction": {"type": "number", "description": "fraction during unoccupied hours (0–1)"}
            },
            "required": ["lights_density", "after_hours_fraction"]
        },
	  "electric_equipment": {
		  "type": "object",
            "properties": {
                "electric_equipment_density": {
					"type": "object",
					"properties": {
						"calculation_method": {
							"type": "string",
							"enum": ["EquipmentLevel", "Watts/Area", "Watts/Person"]
						},
						"value": {
							"type": "number",
							"description": "The amount of equipment power according to the calculation_method"
						}
					}
				},
				"after_hours_fraction": {"type": "number", "description": "fraction during unoccupied hours (0–1)"}
            },
            "required": ["electric_equipment_density", "after_hours_fraction"]  
        }
	},
	"required": ["people", "lights", "electric_equipment"],
	"additionalProperties": false
  }
}
  

